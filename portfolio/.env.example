# Optional environment variables for the portfolio site.
# Copy this file to .env and fill in values as needed.

# Set this if deploying to a GitHub project page (e.g. /repo-name/)
# Leave empty for a user root page (username.github.io)
# BASE_PATH=/Website

# Formspree form endpoint ID for the contact form
# Sign up at https://formspree.io and create a new form to get your ID
# PUBLIC_FORMSPREE_ID=your_form_id_here
